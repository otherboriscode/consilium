# /etc/consilium/.env — copy this template, fill in real values, and put
# the result in /etc/consilium/.env on the VPS (chmod 640, root:consilium).
# NEVER commit the real file.

# ---------- Provider keys ----------
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENROUTER_API_KEY=sk-or-v1-...
PERPLEXITY_API_KEY=pplx-...

# ---------- Consilium server ----------
# Generate once: openssl rand -hex 32
CONSILIUM_API_TOKEN=replace-with-32-random-bytes-hex
CONSILIUM_DATA_DIR=/var/lib/consilium
CONSILIUM_LIMITS_FILE=/etc/consilium/limits.yaml

# ---------- Telegram bot ----------
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_ALLOWED_USER_IDS=12345678
# Bot reaches the local API on the loopback interface.
CONSILIUM_API_BASE=http://127.0.0.1:8421

# ---------- Backups (Backblaze B2 via restic) ----------
# Skip these if you haven't set up B2 yet — backup timer will simply fail.
B2_ACCOUNT_ID=...
B2_APPLICATION_KEY=...
RESTIC_REPOSITORY=b2:consilium-backups:/
# Generate once and store in 1Password: openssl rand -hex 32
RESTIC_PASSWORD=replace-with-32-random-bytes-hex
