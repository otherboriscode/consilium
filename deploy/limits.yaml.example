# /etc/consilium/limits.yaml — five-level cost protection.
# Mode: read at server start, applied per-job. Edit and `systemctl restart
# consilium-api` to take effect. See consilium/limits.py for full semantics.

max_cost_per_job_usd: 25.0
max_cost_per_day_usd: 50.0
max_cost_per_month_usd: 300.0
hard_stop_per_month_usd: 500.0

# Structural caps — refuse a job that's structurally out of bounds, not
# just expensive.
max_rounds: 4
max_tokens_per_response: 16000
max_context_tokens: 800000

# Send 50/80/95% alerts via /budget/alerts.
alert_thresholds: [0.5, 0.8, 0.95]
